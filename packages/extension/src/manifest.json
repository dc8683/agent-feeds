{
  "manifest_version": 3,
  "name": "Agent Feeds",
  "version": "0.1.0",
  "description": "聚合小红书/B站/抖音关注内容到本地 Feed",
  "permissions": ["cookies", "storage", "alarms", "tabs"],
  "host_permissions": [
    "*://*.xiaohongshu.com/*",
    "*://*.bilibili.com/*",
    "*://*.douyin.com/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": [
        "*://*.xiaohongshu.com/*",
        "*://*.bilibili.com/*",
        "*://*.douyin.com/*"
      ],
      "js": ["content.js"]
    }
  ],
  "action": {
    "default_popup": "popup.html"
  }
}
